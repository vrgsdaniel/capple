# ── Backend ───────────────────────────────────────────────────────────────────
SERVICE_NAME=capple
ENV=dev
HOST=0.0.0.0
PORT=8080

# OpenTelemetry (set OPENTELEMETRY=true to enable)
OPENTELEMETRY=false
OTEL_EXPORTER_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp/v1/traces
OTEL_EXPORTER_HEADERS=Authorization=Basic <base64(instanceId:token)>
