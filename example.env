# ── Backend ───────────────────────────────────────────────────────────────────
SERVICE_NAME=capple
ENV=dev
HOST=0.0.0.0
PORT=8080

# OpenTelemetry (set OPENTELEMETRY=true to enable)
OPENTELEMETRY=false
OTEL_EXPORTER_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp/v1/traces
OTEL_EXPORTER_HEADERS=Authorization=Basic <base64(instanceId:token)>

# LLM
LLM_PROVIDER=openai
LLM_STREAM=true
LLM_TEMPERATURE=0.3
LLM_MAX_RETRIES=2

# OpenAI / LLM Gateway (set BASE_URL to https://api.llmgateway.io/v1 and MODEL=auto for gateway)
LLM_OPEN_AI_MODEL=gpt-4o-mini
LLM_OPEN_AI_API_KEY=replace-with-openai-or-llmgateway-api-key
LLM_OPEN_AI_BASE_URL=
LLM_OPEN_AI_FREE_MODELS_ONLY=false

# Azure OpenAI (only used when LLM_PROVIDER=azure)
LLM_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
LLM_AZURE_DEPLOYMENT=gpt-4o-mini
LLM_OPEN_AI_VERSION=2024-10-21
LLM_AZURE_OPENAI_API_KEY=replace-with-azure-openai-api-key

# Optional LangSmith
LLM_LANGSMITH_API_KEY=
LLM_LANGSMITH_TRACING=false
LLM_LANGSMITH_PROJECT=capple
